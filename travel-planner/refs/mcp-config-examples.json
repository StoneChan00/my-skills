{
  "// 说明": "以下所有配置使用 OpenCode 的 `mcp` schema（非 Claude Desktop 的 mcpServers）。复制到 opencode.json 顶层 `mcp` 字段即可。",

  "场景A: 国内火车票 + 国际旅行（推荐组合）": {
    "mcp": {
      "12306": {
        "type": "local",
        "command": ["npx", "-y", "12306-mcp"],
        "enabled": true,
        "timeout": 30000,
        "_comment": "国内火车票首选，v0.3.8 npm 实测可用"
      },
      "nowah-travel": {
        "type": "remote",
        "url": "https://claw.nowah.xyz/mcp",
        "enabled": true,
        "oauth": true,
        "timeout": 30000,
        "_comment": "国际航班/酒店/POI，首次使用需 `opencode mcp auth nowah-travel` 认证"
      }
    }
  },

  "场景B: 纯国内旅行（轻量）": {
    "mcp": {
      "12306": {
        "type": "local",
        "command": ["npx", "-y", "12306-mcp"],
        "enabled": true,
        "timeout": 30000
      },
      "amap": {
        "type": "local",
        "command": ["npx", "-y", "@modelcontextprotocol/server-amap"],
        "environment": {
          "AMAP_MAPS_API_KEY": "${AMAP_MAPS_API_KEY}"
        },
        "enabled": true
      }
    }
  },

  "场景C: 纯国际旅行": {
    "mcp": {
      "nowah-travel": {
        "type": "remote",
        "url": "https://claw.nowah.xyz/mcp",
        "enabled": true,
        "oauth": true,
        "timeout": 30000
      },
      "google-maps": {
        "type": "local",
        "command": ["npx", "-y", "@modelcontextprotocol/server-google-maps"],
        "environment": {
          "GOOGLE_MAPS_API_KEY": "${GOOGLE_MAPS_API_KEY}"
        },
        "enabled": true
      }
    }
  },

  "场景D: 高频 12306 查询（Docker 长驻）": {
    "docker 启动命令": "docker run -d -p 8000:8000 --name mcp-12306 drfccv/mcp-server-12306:latest",
    "mcp": {
      "12306": {
        "type": "remote",
        "url": "http://localhost:8000/mcp",
        "enabled": true,
        "timeout": 60000
      }
    }
  },

  "场景E: 临时禁用某个 MCP": {
    "mcp": {
      "nowah-travel": {
        "type": "remote",
        "url": "https://claw.nowah.xyz/mcp",
        "enabled": false,
        "_comment": "临时关闭，节省 context 空间"
      }
    }
  },

  "场景F: 飞猪 Skill 接入（通过 OpenClaw，不是 MCP）": {
    "说明": "飞猪 FlyAI 不是 MCP server，而是 OpenClaw 的 Skill 包",
    "前置条件": "需要先安装 OpenClaw 客户端",
    "安装命令 1": "clawhub install flyai",
    "安装命令 2": "npx skills add alibaba-flyai/flyai-skill",
    "限制": "API Key 需企业认证，个人通过 OpenClaw 额度低"
  }
}
